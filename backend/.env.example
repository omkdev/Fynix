# Copy to .env and fill in values. Never commit real secrets.

# Database (Supabase / Postgres)
DATABASE_URL=
DIRECT_URL=

# Auth — required; use two different values (e.g. openssl rand -hex 64 each)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# CORS + HttpOnly cookies — must match `FRONTEND_ORIGIN` in backend/src/index.js exactly
# (not FRONTEND_URL / CORS_ORIGIN). Default CRA dev server: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
PORT=4000
NODE_ENV=development
